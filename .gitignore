# =============================================================================
# Odal Node — .gitignore
# Public repo: github.com/odal-node/dpp-core
# =============================================================================

# Keycloak dev realm (generated from template)
ops/docker/keycloak/*-realm.json
!ops/docker/keycloak/*-realm.template.json

# -----------------------------------------------------------------------------
# SECRETS & ENVIRONMENT
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
# RUST
# -----------------------------------------------------------------------------
/target/
# The sector plugins are excluded from the main workspace (different toolchain
# target) and form their own workspace at plugins/Cargo.toml, with its own
# shared target dir. /target/ above only anchors to the repo root, so it's
# listed explicitly; the second pattern catches any pre-restructuring
# per-member target dirs left over locally.
plugins/target/
plugins/*/target/
Cargo.lock
**/*.rs.bak

# -----------------------------------------------------------------------------
# EDITOR & OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# BUILD ARTIFACTS
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
coverage/
.nyc_output/